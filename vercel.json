{
    "version": 2,
    "name": "migration-wizard-app",
    "builds": [
        {
            "src": "migration-app/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "migration-app/dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/migration-app/$1"
        }
    ]
}